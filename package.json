{
  "name": "sudoku-cf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "deploy:api": "npm --workspace apps/api run deploy",
    "deploy": "npm run build:web && npm run deploy:api",
    "migrate": "npm --workspace apps/api run migrate",
    "setup:cf": "tsx scripts/setup-cloudflare.ts",
    "typecheck": "npm --workspace apps/api run typecheck && npm --workspace apps/web run typecheck",
    "seed:puzzles": "tsx scripts/seed-puzzles.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}